# Backend Configuration
# Copy this to .env and update values for different environments

# Flask Environment
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_APP=app.py

# Server Configuration
HOST=0.0.0.0
PORT=5000

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# API Configuration
API_VERSION=1.0.0
API_TITLE=Diabetes Prediction API
API_DESCRIPTION=ML API for diabetes risk prediction and glucose estimation
